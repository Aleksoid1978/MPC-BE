            MENUITEM "Đặt lại cài đặt bộ kết xuất về mặc định", ID_VIEW_RESET_DEFAULT
        END
        POPUP "Chế độ Stereo 3D"
        BEGIN
            MENUITEM "Tự động",                        ID_STEREO3D_AUTO
            MENUITEM "Mono",                        ID_STEREO3D_MONO
            MENUITEM "Row Interleaved",             ID_STEREO3D_ROW_INTERLEAVED
            MENUITEM "Row Interleaved (2x)",        ID_STEREO3D_ROW_INTERLEAVED_2X
            MENUITEM "Half OverUnder",              ID_STEREO3D_HALFOVERUNDER
            MENUITEM "OverUnder",                   ID_STEREO3D_OVERUNDER
            MENUITEM SEPARATOR
            MENUITEM "Đổi trái/phải",             ID_STEREO3D_SWAP_LEFTRIGHT
        END
        MENUITEM SEPARATOR
        MENUITEM "Thuộc t&ính",                 ID_FILE_PROPERTIES
        MENUITEM "&Tùy chọn...",                 ID_VIEW_OPTIONS
        MENUITEM SEPARATOR
        MENUITEM "Th&oát",                       ID_FILE_EXIT
    END
END

