    IDS_CMD_DVD             "/dvd\tChạy ở chế độ dvd, ""tên_đường_dẫn"" nghĩa là thư mục\ndvd (tùy chọn)"
    IDS_CMD_DVDPOS1         "/dvdpos T#C\tBắt đầu phát tại tiêu đề T, chương C"
    IDS_CMD_DVDPOS2         "/dvdpos T#hh:mm\tBắt đầu phát tại tiêu đề T, vị trí hh:mm:ss"
    IDS_CMD_CD              "/cd\tTải tất cả các bản nhạc của một cd âm thanh hoặc (s)vcd,\n""tên_đường_dẫn"" nghĩa là đường dẫn ổ đĩa (tùy chọn)"
    IDS_CMD_OPEN            "/open\tMở tệp, không tự động bắt đầu phát"
    IDS_CMD_PLAY            "/play\tBắt đầu phát tệp ngay khi trình phát được\nkhởi chạy"
    IDS_CMD_CLOSE           "/close\tĐóng trình phát sau khi phát xong (chỉ hoạt động khi\ndùng với /play)"
    IDS_CMD_SHUTDOWN        "/shutdown\tTắt hệ điều hành sau khi phát xong"
    IDS_CMD_FULLSCREEN      "/fullscreen\tBắt đầu ở chế độ toàn màn hình"
    IDS_CMD_MINIMIZED       "/minimized\tBắt đầu ở chế độ thu nhỏ"
    IDS_CMD_NEW             "/new\tSử dụng một phiên bản (instance) mới của trình phát"
    IDS_CMD_ADD             "/add\tThêm ""tên_đường_dẫn"" vào danh sách phát, có thể kết hợp\nvới /open và /play"
END

